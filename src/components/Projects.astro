---
const projects = [
  {
    name: 'Web3Agent',
    description: 'AI-driven platform that lets users execute complex blockchain operations through natural language commands.',
    tags: ['LangChain', 'CrewAI', 'Solidity', 'React.js', 'Web3'],
    url: 'https://ethglobal.com/showcase/web3agent-t6vjn',
    highlight: '$10K+ hackathon wins',
    category: 'AI + Blockchain',
  },
  {
    name: 'Web3Agent 2.0',
    description: 'Second iteration with enhanced multi-chain support, improved natural language processing, and expanded DeFi operation capabilities.',
    tags: ['LangChain', 'CrewAI', 'Solidity', 'Multi-Chain', 'Web3'],
    url: 'https://ethglobal.com/showcase/web3agent-2-0-uin2x',
    category: 'AI + Blockchain',
  },
  {
    name: 'Private AI',
    description: 'Privacy-first AI agents with encrypted backend systems and real-time sentiment analysis.',
    tags: ['LangChain', 'AutoGen', 'FastAPI', 'CrewAI'],
    url: 'https://www.privateai.com',
    category: 'AI',
  },
  {
    name: 'Currently.social',
    description: 'AI-powered social platform with LLM-driven personalization, content recommendations, and moderation.',
    tags: ['Python', 'FastAPI', 'OpenAI', 'CrewAI', 'AWS'],
    url: 'https://currently.social',
    category: 'AI',
  },
  {
    name: 'TrustSwap',
    description: 'DeFi staking smart contracts enabling secure and efficient token staking for thousands of users.',
    tags: ['Solidity', 'DeFi', 'Web3', 'React.js'],
    url: 'https://trustswap.com',
    category: 'DeFi',
  },
  {
    name: 'Velvet Capital',
    description: 'DeFi asset management protocol with multi-chain portfolio rebalancing and yield optimization.',
    tags: ['Solidity', 'DeFi', 'Tokenomics', 'Multi-Chain'],
    url: 'https://www.velvet.capital',
    category: 'DeFi',
  },
  {
    name: 'PHPT — Philippine Stablecoin',
    description: 'Philippine Peso-pegged stablecoin and exchange platform. Built core Solidity contracts for minting, burning, on-chain settlement, plus a Telegram-based payment wallet (2020).',
    tags: ['Solidity', 'Stablecoin', 'ERC-20', 'Telegram Bot', 'DeFi'],
    url: 'https://phpt.com',
    category: 'DeFi',
  },
  {
    name: 'Cointopper',
    description: 'Full-stack cryptocurrency management and trading platform with real-time dashboards and multi-account operations.',
    tags: ['PHP', 'Laravel', 'Angular.js', 'MySQL'],
    url: 'https://cointopper.com',
    category: 'Full-Stack',
  },
  {
    name: 'The Thing - Private AI',
    description: 'Privacy-first AI platform with encrypted backend systems, decentralized storage, and real-time sentiment analysis.',
    tags: ['LangChain', 'AutoGen', 'CrewAI', 'FastAPI'],
    url: 'https://thething.privateai.com',
    category: 'AI',
  },
  {
    name: 'Wallet-as-a-Service',
    description: 'Secure, scalable digital asset management platform with multi-chain support and multi-sig wallets.',
    tags: ['Smart Contracts', 'Multi-Chain', 'Node.js', 'REST APIs'],
    category: 'Blockchain',
  },
];
---

<section id="projects" class="py-24 px-6 bg-surface">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <p class="font-mono text-sm text-accent tracking-wide mb-3">Portfolio</p>
    <h2 class="font-sans text-3xl md:text-4xl font-bold text-text mb-2">Projects</h2>
    <div class="w-12 h-0.5 bg-accent mb-6"></div>
    <p class="text-muted text-base leading-relaxed mb-14">
      A selection of projects spanning AI agents, DeFi protocols, and full-stack platforms.
    </p>

    <!-- Visual -->
    <div class="mb-12 rounded-xl overflow-hidden border border-border/40">
      <img src="/images/projects-visual.jpg" alt="DeFi and AI project visualization" class="w-full h-40 md:h-48 object-cover opacity-85" loading="lazy" />
    </div>

    <!-- Project grid — 2 columns on desktop -->
    <div class="grid md:grid-cols-2 gap-5">
      {projects.map((project, i) => (
        <div class={`bg-card rounded-xl border border-border/60 overflow-hidden card-hover group
          ${i === 0 ? 'md:col-span-2' : ''}`}
        >
          {/* Category bar */}
          <div class="h-[3px] bg-gradient-to-r from-accent/60 via-accent/20 to-transparent"></div>

          <div class="p-6">
            {/* Header */}
            <div class="flex items-start justify-between gap-3 mb-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <span class="font-mono text-[10px] text-accent/60 uppercase tracking-wider">{project.category}</span>
                  {project.highlight && (
                    <span class="font-mono text-[10px] font-medium bg-accent text-white px-2 py-0.5 rounded-full">
                      {project.highlight}
                    </span>
                  )}
                </div>
                <h3 class="font-sans text-lg font-semibold text-text group-hover:text-accent transition-colors">
                  {project.name}
                </h3>
              </div>
              {project.url && (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-muted hover:text-accent transition-colors shrink-0 p-2 rounded-lg hover:bg-accent/5 mt-1"
                  aria-label={`Visit ${project.name}`}
                >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>

            {/* Description */}
            <p class="text-muted text-sm leading-relaxed mb-4">{project.description}</p>

            {/* Tags */}
            <div class="flex flex-wrap gap-1.5">
              {project.tags.map((tag) => (
                <span class="font-mono text-[11px] px-2 py-0.5 rounded-md bg-surface text-muted border border-border/40 hover:border-accent/30 hover:text-accent transition-colors">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

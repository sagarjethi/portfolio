---
const experiences = [
  {
    company: 'Code Minto',
    role: 'Founder · Blockchain Consulting & Development',
    type: 'Self-employed',
    period: '2019 - Present',
    points: [
      'Founded and run a blockchain consulting firm delivering smart contract development, architecture, and advisory for 30+ clients.',
      'Shipped production systems across DeFi, tokenization, staking, NFT marketplaces, and multi-chain integrations.',
      'End-to-end technical consulting from product research to mainnet deployment.',
    ],
    current: true,
    featured: true,
  },
  {
    company: 'Stealth Startup',
    role: 'Blockchain Consultant · OnRamp/OffRamp Aggregator & Crypto Payment Product',
    type: 'Part-time',
    period: 'Jan 2026 - Present',
    points: [
      'Building the full OnRamp/OffRamp Aggregator end-to-end with smart routing across Transak, MoonPay, and Ramp Network.',
      'Handling KYC/AML compliance, payment rails, wallet settlement, and smart contract development.',
      'End-to-end technical documentation and product research for crypto payment infrastructure.',
    ],
    current: true,
  },
  {
    company: 'Gintonic AI',
    role: 'Full Stack Product Developer',
    type: 'Contract',
    period: 'Dec 2024 - Dec 2025',
    points: [
      'Engineered LLM-powered AI agents with LangChain, CrewAI, and AutoGen for real-time function calling and API integrations.',
      'Deployed smart contracts (ERC-20, ERC-721, ERC-1155) for AI-driven decentralized applications.',
    ],
  },
  {
    company: 'Private AI',
    url: 'https://www.privateai.com/',
    role: 'Product Research & AI Backend Developer',
    type: 'Full-time',
    period: '2024',
    points: [
      'Architected encrypted backend systems and deployed privacy-first AI agents using LLM frameworks.',
      'Built AI-powered sentiment analysis for Twitter with real-time insights.',
    ],
  },
  {
    company: 'Velvet Capital',
    url: 'https://www.velvet.capital/',
    role: 'Core Team, Blockchain Architect',
    type: 'Full-time',
    period: '2022',
    points: [
      'Researched and analyzed DeFi products across tokenomics, liquidity protocols, and yield optimization.',
      'Architected multi-chain integrations improving platform interoperability and token utility.',
    ],
  },
  {
    company: 'Independent Consultant',
    role: 'Blockchain Development',
    type: 'Freelance',
    period: '2019 - 2021',
    points: [
      'Designed and deployed smart contracts for DeFi platforms, tokenized assets, and NFT marketplaces.',
      'Advised enterprises and startups on blockchain architecture, tokenomics, and governance.',
    ],
  },
  {
    company: 'Nonceblox',
    role: 'Blockchain Architect & Cryptography Researcher',
    type: 'Full-time',
    period: '2021',
    points: [
      'Researched Decentralized Identifiers (DIDs) and decentralized identity frameworks.',
      'Designed and deployed ERC-20 tokens and ICOs with secure contract implementations.',
    ],
  },
  {
    company: 'Techitree Solutions',
    role: 'Senior Consultant, Web Development',
    type: 'Contract',
    period: '2019',
    points: [
      'Built full-stack web applications using React.js, Vue.js, Node.js, and Python.',
      'Led front-end development of responsive interfaces and integrated backend APIs.',
    ],
  },
  {
    company: 'DomusCoins',
    role: 'Blockchain Developer',
    type: 'Full-time',
    period: '2018 - 2019',
    points: [
      'Deployed smart contracts on Ethereum for secure, efficient token operations.',
      'Built decentralized applications integrating frontend interfaces with blockchain backends.',
    ],
  },
  {
    company: 'CodeCrunch TechLabs',
    role: 'Fullstack Developer',
    type: 'Full-time',
    period: '2016 - 2018',
    points: [
      'Built and maintained the studentdesk.in platform with frontend and backend features.',
      'Developed responsive web and mobile applications with cross-platform performance.',
    ],
  },
];
---

<section id="experience" class="py-24 px-6 bg-primary">
  <div class="max-w-3xl mx-auto">
    <!-- Section header -->
    <p class="font-mono text-sm text-accent tracking-wide mb-3">Career Path</p>
    <h2 class="font-sans text-3xl md:text-4xl font-bold text-text mb-2">Experience</h2>
    <div class="w-12 h-0.5 bg-accent mb-6"></div>
    <p class="text-muted text-base leading-relaxed mb-14">
      A decade of building across AI, blockchain, and full-stack development.
    </p>

    <!-- Experience entries -->
    <div class="space-y-0">
      {experiences.map((exp, i) => (
        <div class={`group relative ${i !== experiences.length - 1 ? 'pb-8' : ''}`}>
          {/* Connecting line */}
          {i !== experiences.length - 1 && (
            <div class="absolute left-[19px] top-[40px] bottom-0 w-px bg-gradient-to-b from-border to-border/30"></div>
          )}

          <div class="flex gap-5">
            {/* Left: dot + line */}
            <div class="flex-shrink-0 pt-[6px]">
              <div class={`relative w-[38px] h-[38px] rounded-full flex items-center justify-center
                ${exp.current
                  ? 'bg-accent/10 border-2 border-accent'
                  : 'bg-card border-2 border-border group-hover:border-accent/40'
                } transition-colors duration-200`}
              >
                <span class={`text-xs font-mono font-medium ${exp.current ? 'text-accent' : 'text-muted group-hover:text-accent/60'} transition-colors`}>
                  {String(i + 1).padStart(2, '0')}
                </span>
              </div>
            </div>

            {/* Right: content */}
            <div class={`flex-1 ${exp.featured ? 'bg-card border border-accent/20 rounded-xl p-6 shadow-sm' : 'pb-2'}`}>
              {/* Header row */}
              <div class="flex flex-wrap items-center gap-2 mb-1.5">
                {exp.current && (
                  <span class="font-mono text-[10px] font-medium bg-accent text-white px-2 py-0.5 rounded-full">
                    Now
                  </span>
                )}
                <span class="font-mono text-xs text-muted">{exp.period}</span>
                {exp.type && (
                  <span class="font-mono text-[10px] text-muted/60 px-2 py-0.5 rounded-full border border-border/60">
                    {exp.type}
                  </span>
                )}
              </div>

              {/* Company */}
              <div class="mb-0.5">
                {exp.url ? (
                  <a
                    href={exp.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="font-sans text-lg font-semibold text-text hover:text-accent transition-colors inline-flex items-center gap-1.5 link-underline"
                  >
                    {exp.company}
                    <svg class="w-3.5 h-3.5 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                ) : (
                  <span class="font-sans text-lg font-semibold text-text">{exp.company}</span>
                )}
              </div>

              {/* Role */}
              <p class="text-sm text-accent/80 mb-4">{exp.role}</p>

              {/* Points */}
              <ul class="space-y-2">
                {exp.points.map((point) => (
                  <li class="text-muted text-sm leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[8px] before:w-1 before:h-1 before:rounded-full before:bg-accent/40">
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

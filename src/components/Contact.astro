---
const socials = [
  {
    label: 'GitHub',
    url: 'https://github.com/sagarjethi',
    icon: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />',
  },
  {
    label: 'X / Twitter',
    url: 'https://x.com/sagarbjethi',
    icon: '<path d="M4 4l11.733 16H20L8.267 4z" /><path d="M4 20l6.768-6.768M15.232 10.232L20 4" />',
  },
  {
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/sagarjethi',
    icon: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" />',
  },
];
---

<section id="contact" class="py-24 px-6 relative overflow-hidden">
  <div class="absolute top-0 left-1/3 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-0 right-1/3 w-72 h-72 bg-accent/3 rounded-full blur-3xl"></div>

  <div class="relative max-w-xl mx-auto">
    <div class="text-center mb-12">
      <span class="font-fira text-xs text-accent tracking-widest uppercase block mb-3">Let's Connect</span>
      <h2 class="font-sora text-3xl md:text-4xl font-bold inline-block section-title">Get in Touch</h2>
      <p class="text-muted mt-6">Have a project in mind or want to collaborate? Drop me a message.</p>
    </div>

    <div class="glow-card rounded-xl p-8">
      <form action="https://formspree.io/f/xcontact" method="POST" class="space-y-5">
        <div>
          <label for="name" class="font-fira text-xs text-muted block mb-2 tracking-wide">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm focus:border-accent focus:outline-none focus:shadow-lg focus:shadow-accent/10 transition-all"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="font-fira text-xs text-muted block mb-2 tracking-wide">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm focus:border-accent focus:outline-none focus:shadow-lg focus:shadow-accent/10 transition-all"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="message" class="font-fira text-xs text-muted block mb-2 tracking-wide">Message</label>
          <textarea
            name="message"
            id="message"
            rows="5"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm focus:border-accent focus:outline-none focus:shadow-lg focus:shadow-accent/10 transition-all resize-none"
            placeholder="Tell me about your project..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="font-fira text-sm bg-accent text-primary px-8 py-3.5 rounded-lg font-medium hover:bg-accent/90 transition-all duration-200 w-full shadow-lg shadow-accent/20"
        >
          Send Message
        </button>
      </form>
    </div>

    <div class="flex justify-center gap-4 mt-8">
      {socials.map(social => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="w-12 h-12 rounded-lg border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent/30 hover:bg-accent/5 transition-all duration-200"
          aria-label={social.label}
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <Fragment set:html={social.icon} />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

---
const socials = [
  {
    label: 'GitHub',
    url: 'https://github.com/sagarjethi',
    icon: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />',
  },
  {
    label: 'X / Twitter',
    url: 'https://x.com/sagarbjethi',
    icon: '<path d="M4 4l11.733 16H20L8.267 4z" /><path d="M4 20l6.768-6.768M15.232 10.232L20 4" />',
  },
  {
    label: 'LinkedIn',
    url: 'https://www.linkedin.com/in/sagarjethi',
    icon: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" /><rect width="4" height="12" x="2" y="9" /><circle cx="4" cy="4" r="2" />',
  },
];
---

<section id="contact" class="py-20 px-6 bg-surface">
  <div class="max-w-xl mx-auto">
    <div class="mb-14">
      <h2 class="font-sans text-2xl md:text-3xl font-bold text-text">
        Get in Touch
      </h2>
      <div class="mt-2 w-10 h-1 rounded-full bg-accent"></div>
      <p class="text-muted text-sm mt-4">Have a project in mind or want to collaborate? Drop me a message.</p>
    </div>

    <div class="bg-card border border-border rounded-xl p-8">
      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5" id="contact-form">
        <input type="hidden" name="access_key" value="fcf8ab9b-cba7-4e86-bc6e-597cbf576798" />
        <input type="hidden" name="subject" value="New contact from sagarjethi.com" />
        <input type="hidden" name="from_name" value="Portfolio Contact Form" />
        <input type="checkbox" name="botcheck" class="hidden" />
        <div>
          <label for="name" class="font-mono text-xs text-muted block mb-2 tracking-wide">Name</label>
          <input
            type="text"
            name="name"
            id="name"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm font-sans focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/10 transition-all placeholder:text-muted/50"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="font-mono text-xs text-muted block mb-2 tracking-wide">Email</label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm font-sans focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/10 transition-all placeholder:text-muted/50"
            placeholder="you@example.com"
          />
        </div>
        <div>
          <label for="message" class="font-mono text-xs text-muted block mb-2 tracking-wide">Message</label>
          <textarea
            name="message"
            id="message"
            rows="5"
            required
            class="w-full bg-primary border border-border rounded-lg px-4 py-3 text-text text-sm font-sans focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/10 transition-all resize-none placeholder:text-muted/50"
            placeholder="Tell me about your project..."
          ></textarea>
        </div>
        <button
          type="submit"
          id="submit-btn"
          class="font-sans text-sm bg-accent text-white px-8 py-3 rounded-lg font-medium hover:bg-[#D4652E] transition-all duration-200 w-full"
        >
          Send Message
        </button>
        <!-- Success/Error feedback -->
        <div id="form-success" class="hidden text-center py-3 px-4 rounded-lg bg-green-50 border border-green-200 text-green-700 text-sm">
          Message sent successfully! I'll get back to you soon.
        </div>
        <div id="form-error" class="hidden text-center py-3 px-4 rounded-lg bg-red-50 border border-red-200 text-red-600 text-sm">
          Something went wrong. Please try again or email me directly.
        </div>
      </form>
    </div>

    <script is:inline>
      const form = document.getElementById('contact-form');
      const btn = document.getElementById('submit-btn');
      const successMsg = document.getElementById('form-success');
      const errorMsg = document.getElementById('form-error');

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        btn.textContent = 'Sending...';
        btn.disabled = true;

        try {
          const resp = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(new FormData(form))),
          });
          const data = await resp.json();
          if (data.success) {
            successMsg.classList.remove('hidden');
            errorMsg.classList.add('hidden');
            form.reset();
          } else {
            throw new Error('Failed');
          }
        } catch {
          errorMsg.classList.remove('hidden');
          successMsg.classList.add('hidden');
        }
        btn.textContent = 'Send Message';
        btn.disabled = false;
      });
    </script>

    <div class="flex gap-3 mt-8">
      {socials.map(social => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="w-10 h-10 rounded-lg border border-border flex items-center justify-center text-muted hover:text-accent hover:border-accent/30 transition-colors duration-200"
          aria-label={social.label}
        >
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <Fragment set:html={social.icon} />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

---

---

<section id="hero" class="py-20 px-6 relative overflow-hidden">
  <!-- Background illustration -->
  <div class="absolute inset-0 opacity-[0.06]">
    <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" />
  </div>
  <div class="max-w-3xl mx-auto relative">
    <!-- Greeting -->
    <p class="font-mono text-sm text-accent tracking-wide mb-4 animate-fade-in animate-fade-in-d1">Hello, welcome</p>
    <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-tight mb-6 animate-fade-in animate-fade-in-d2">
      I build production blockchain systems that handle <span class="text-accent">real money</span> and <span class="text-accent">real users</span>.
    </h1>
    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mb-12 animate-fade-in animate-fade-in-d3">
      Over 10 years of shipping smart contracts, DeFi protocols, and AI-powered platforms —
      from architecture to mainnet.
    </p>

    <!-- Stats -->
    <div class="flex flex-wrap items-center gap-8 md:gap-12 mb-12 animate-fade-in animate-fade-in-d4">
      <div>
        <span class="font-sans text-2xl md:text-3xl font-bold text-accent stat-number">30+</span>
        <span class="block font-mono text-xs text-muted mt-1 tracking-wide uppercase">Projects Delivered</span>
      </div>
      <div class="hidden sm:block w-px h-10 bg-border"></div>
      <div>
        <span class="font-sans text-2xl md:text-3xl font-bold text-accent stat-number">20+</span>
        <span class="block font-mono text-xs text-muted mt-1 tracking-wide uppercase">Hackathons Won & Judged</span>
      </div>
      <div class="hidden sm:block w-px h-10 bg-border"></div>
      <div>
        <span class="font-sans text-2xl md:text-3xl font-bold text-accent stat-number">2,000+</span>
        <span class="block font-mono text-xs text-muted mt-1 tracking-wide uppercase">Developers Educated</span>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animate-fade-in-d5">
      <a
        href="#projects"
        class="inline-flex items-center justify-center font-sans text-sm font-medium bg-accent text-white px-8 py-3.5 rounded-lg hover:bg-[#D4652E] transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-accent/10"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center font-sans text-sm font-medium border border-border text-muted px-8 py-3.5 rounded-lg hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>

---

---

<section id="hero" class="py-20 md:py-28 px-6 relative overflow-hidden min-h-[85vh] flex items-center">
  <!-- Background illustration -->
  <div class="absolute inset-0 opacity-[0.04]">
    <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" />
  </div>

  <!-- Floating meaningful symbols -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <!-- Blockchain hexagon — represents decentralization -->
    <svg class="hero-float absolute top-[12%] right-[8%] w-16 h-16 text-accent/[0.07]" viewBox="0 0 100 100" fill="currentColor" style="animation-delay: 0s;">
      <polygon points="50,5 93,25 93,75 50,95 7,75 7,25" />
    </svg>

    <!-- Smart contract brackets { } — the code -->
    <span class="hero-float absolute top-[22%] right-[22%] font-mono text-5xl text-accent/[0.06] font-bold select-none" style="animation-delay: 1.5s;">{ }</span>

    <!-- Chain link — trust, connection -->
    <svg class="hero-float absolute bottom-[25%] right-[12%] w-12 h-12 text-accent/[0.08]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: 0.8s;">
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
    </svg>

    <!-- Neural network node — AI -->
    <svg class="hero-float absolute top-[35%] right-[4%] w-10 h-10 text-accent/[0.06]" viewBox="0 0 24 24" fill="currentColor" style="animation-delay: 2.2s;">
      <circle cx="12" cy="12" r="3" />
      <circle cx="4" cy="6" r="2" />
      <circle cx="20" cy="6" r="2" />
      <circle cx="4" cy="18" r="2" />
      <circle cx="20" cy="18" r="2" />
      <line x1="12" y1="9" x2="4" y2="6" stroke="currentColor" stroke-width="0.5" />
      <line x1="12" y1="9" x2="20" y2="6" stroke="currentColor" stroke-width="0.5" />
      <line x1="12" y1="15" x2="4" y2="18" stroke="currentColor" stroke-width="0.5" />
      <line x1="12" y1="15" x2="20" y2="18" stroke="currentColor" stroke-width="0.5" />
    </svg>

    <!-- Ethereum diamond — the ecosystem -->
    <svg class="hero-float absolute bottom-[15%] right-[28%] w-8 h-8 text-accent/[0.07]" viewBox="0 0 24 24" fill="currentColor" style="animation-delay: 3s;">
      <path d="M12 1.5L3 12l9 10.5L21 12z" opacity="0.6" />
      <path d="M12 1.5L3 12l9 4.5 9-4.5z" opacity="0.8" />
    </svg>

    <!-- Binary dots — data flow -->
    <div class="hero-float absolute top-[55%] right-[18%] font-mono text-[10px] text-accent/[0.06] leading-tight select-none tracking-widest" style="animation-delay: 1s;">
      01001<br/>10110<br/>01101
    </div>

    <!-- Shield — security -->
    <svg class="hero-float absolute top-[8%] right-[38%] w-10 h-10 text-accent/[0.05]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="animation-delay: 2.8s;">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
      <path d="M9 12l2 2 4-4" />
    </svg>

    <!-- Subtle grid dots — bottom left -->
    <div class="absolute bottom-[10%] left-[5%] grid grid-cols-4 gap-3 opacity-[0.04]" style="animation: none;">
      {Array.from({length: 16}).map(() => (
        <div class="w-1.5 h-1.5 rounded-full bg-accent"></div>
      ))}
    </div>

    <!-- Connecting line — architecture -->
    <svg class="hero-float absolute bottom-[40%] left-[3%] w-20 h-20 text-accent/[0.04]" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1" style="animation-delay: 1.8s;">
      <circle cx="20" cy="20" r="6" />
      <circle cx="80" cy="20" r="6" />
      <circle cx="50" cy="80" r="6" />
      <line x1="20" y1="20" x2="80" y2="20" />
      <line x1="80" y1="20" x2="50" y2="80" />
      <line x1="50" y1="80" x2="20" y2="20" />
    </svg>
  </div>

  <div class="max-w-3xl mx-auto relative">
    <!-- Status badge -->
    <div class="animate-fade-in animate-fade-in-d1 mb-6">
      <span class="inline-flex items-center gap-2 font-mono text-xs text-accent bg-accent/5 border border-accent/15 px-3 py-1.5 rounded-full">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent/60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Available for blockchain consulting
      </span>
    </div>

    <!-- Main headline -->
    <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-[1.15] mb-6 animate-fade-in animate-fade-in-d2">
      I build production blockchain<br class="hidden md:block" />
      systems that handle<br class="hidden md:block" />
      <span class="text-accent relative">
        real money
        <svg class="absolute -bottom-1 left-0 w-full h-2 text-accent/20" viewBox="0 0 200 8" preserveAspectRatio="none">
          <path d="M0 7 C50 0, 100 0, 200 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span> and <span class="text-accent relative">
        real users
        <svg class="absolute -bottom-1 left-0 w-full h-2 text-accent/20" viewBox="0 0 200 8" preserveAspectRatio="none">
          <path d="M0 7 C50 0, 100 0, 200 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>.
    </h1>

    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mb-12 animate-fade-in animate-fade-in-d3">
      Over 10 years of shipping smart contracts, DeFi protocols, and AI-powered platforms —
      from architecture to mainnet.
    </p>

    <!-- Stats with icons -->
    <div class="flex flex-wrap items-start gap-8 md:gap-12 mb-12 animate-fade-in animate-fade-in-d4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round" />
            <path d="M22 4L12 14.01l-3-3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">30+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Projects Delivered</span>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">20+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Hackathons Won & Judged</span>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">2,000+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Developers Educated</span>
        </div>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animate-fade-in-d5">
      <a
        href="#projects"
        class="group inline-flex items-center justify-center gap-2 font-sans text-sm font-medium bg-accent text-white px-8 py-3.5 rounded-lg hover:bg-[#D4652E] transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-accent/10"
      >
        View My Work
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center font-sans text-sm font-medium border border-border text-muted px-8 py-3.5 rounded-lg hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>

<style>
  /* Floating animation for meaningful symbols */
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33% { transform: translateY(-8px) rotate(1deg); }
    66% { transform: translateY(4px) rotate(-1deg); }
  }
  .hero-float {
    animation: heroFloat 8s ease-in-out infinite;
  }
</style>

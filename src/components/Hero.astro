---

---

<section id="hero" class="relative pt-32 pb-20 px-6 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 dot-pattern opacity-30"></div>
  <div class="absolute top-20 left-1/4 w-72 h-72 bg-accent/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-1/4 w-96 h-96 bg-accent/3 rounded-full blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <!-- Photo with glow ring -->
    <div class="mb-8 relative inline-block">
      <div class="absolute inset-0 w-36 h-36 mx-auto rounded-full bg-accent/20 blur-xl"></div>
      <img
        src="/photo.jpg"
        alt="Sagar Jethi"
        class="relative w-32 h-32 rounded-full mx-auto object-cover object-top border-3 border-accent/40 shadow-lg shadow-accent/10"
        loading="eager"
      />
    </div>

    <!-- Name with decorative treatment -->
    <div class="mb-2">
      <span class="font-fira text-xs text-muted tracking-widest uppercase">Hello, I'm</span>
    </div>
    <h1 class="font-sora text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-4">
      Sagar <span class="text-accent">Jethi</span>
    </h1>

    <!-- Roles -->
    <div class="flex flex-wrap items-center justify-center gap-2 mb-6">
      <span class="font-fira text-xs px-3 py-1.5 rounded-full border border-accent/30 text-accent tracking-wide">Founder, Code Minto</span>
      <span class="font-fira text-xs px-3 py-1.5 rounded-full border border-border text-muted tracking-wide">Blockchain Architect & Smart Contract Engineer</span>
      <span class="font-fira text-xs px-3 py-1.5 rounded-full border border-border text-muted tracking-wide">Chainlink Advocate, Ahmedabad</span>
      <span class="font-fira text-xs px-3 py-1.5 rounded-full border border-border text-muted tracking-wide">Blockchain & AI Educator</span>
      <span class="font-fira text-xs px-3 py-1.5 rounded-full border border-border text-muted tracking-wide">Hackathon Mentor & Judge</span>
    </div>

    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10">
      I build production blockchain systems that handle real money and real users.
      Over <span class="text-text font-semibold">10 years</span>, I've helped <span class="text-text font-semibold">30+ clients</span> ship smart contracts,
      DeFi protocols, and AI-powered platforms — and educated <span class="text-text font-semibold">2,000+ developers</span> along the way.
    </p>

    <!-- Key Achievements -->
    <div class="flex flex-wrap items-center justify-center gap-6 md:gap-10 max-w-3xl mx-auto mb-12">
      <div class="text-center">
        <div class="font-sora text-2xl font-bold text-accent">30+</div>
        <div class="font-fira text-[10px] text-muted mt-0.5 tracking-wide uppercase">Projects & Clients Delivered</div>
      </div>
      <div class="w-px h-8 bg-border/50 hidden md:block"></div>
      <div class="text-center">
        <div class="font-sora text-2xl font-bold text-accent">20+</div>
        <div class="font-fira text-[10px] text-muted mt-0.5 tracking-wide uppercase">Hackathons Won & Judged</div>
      </div>
      <div class="w-px h-8 bg-border/50 hidden md:block"></div>
      <div class="text-center">
        <div class="font-sora text-2xl font-bold text-accent">2,000+</div>
        <div class="font-fira text-[10px] text-muted mt-0.5 tracking-wide uppercase">Developers Educated</div>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="inline-block font-fira text-sm bg-accent text-primary px-8 py-3.5 font-medium hover:bg-accent/90 transition-all duration-200 shadow-lg shadow-accent/20"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="inline-block font-fira text-sm border border-border text-muted px-8 py-3.5 hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 animate-bounce">
      <svg class="w-5 h-5 mx-auto text-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

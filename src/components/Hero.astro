---

---

<section id="hero" class="py-20 md:py-28 px-6 relative overflow-hidden min-h-[85vh] flex items-center">
  <!-- Abstract background -->
  <div class="absolute inset-0 opacity-[0.08]">
    <img src="/images/hero-abstract.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" loading="eager" />
  </div>

  <!-- Floating 3D elements -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Smart contract glass element — top right -->
    <img
      src="/images/hero-element-1.jpg"
      alt=""
      class="hero-float absolute top-[8%] right-[5%] w-28 md:w-36 rounded-2xl opacity-[0.35] mix-blend-multiply"
      style="animation-delay: 0s;"
      loading="eager"
    />
    <!-- Blockchain cube — middle right -->
    <img
      src="/images/hero-element-2.jpg"
      alt=""
      class="hero-float absolute top-[45%] right-[2%] w-24 md:w-32 rounded-2xl opacity-[0.3] mix-blend-multiply"
      style="animation-delay: 2s;"
      loading="eager"
    />
    <!-- AI brain — bottom right -->
    <img
      src="/images/hero-element-3.jpg"
      alt=""
      class="hero-float absolute bottom-[10%] right-[15%] w-20 md:w-28 rounded-2xl opacity-[0.25] mix-blend-multiply"
      style="animation-delay: 4s;"
      loading="eager"
    />
  </div>

  <div class="max-w-3xl mx-auto relative">
    <!-- Status badge -->
    <div class="animate-fade-in animate-fade-in-d1 mb-6">
      <span class="inline-flex items-center gap-2 font-mono text-xs text-accent bg-accent/5 border border-accent/15 px-3 py-1.5 rounded-full">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent/60"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
        </span>
        Available for blockchain consulting
      </span>
    </div>

    <!-- Main headline -->
    <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-[1.15] mb-6 animate-fade-in animate-fade-in-d2">
      I build production blockchain<br class="hidden md:block" />
      systems that handle<br class="hidden md:block" />
      <span class="text-accent relative">
        real money
        <svg class="absolute -bottom-1 left-0 w-full h-2 text-accent/20" viewBox="0 0 200 8" preserveAspectRatio="none">
          <path d="M0 7 C50 0, 100 0, 200 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span> and <span class="text-accent relative">
        real users
        <svg class="absolute -bottom-1 left-0 w-full h-2 text-accent/20" viewBox="0 0 200 8" preserveAspectRatio="none">
          <path d="M0 7 C50 0, 100 0, 200 7" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        </svg>
      </span>.
    </h1>

    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mb-12 animate-fade-in animate-fade-in-d3">
      Over 10 years of shipping smart contracts, DeFi protocols, and AI-powered platforms —
      from architecture to mainnet.
    </p>

    <!-- Stats -->
    <div class="flex flex-wrap items-start gap-8 md:gap-12 mb-12 animate-fade-in animate-fade-in-d4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round" />
            <path d="M22 4L12 14.01l-3-3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">30+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Projects Delivered</span>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">20+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Hackathons Won & Judged</span>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-accent/5 border border-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
          </svg>
        </div>
        <div>
          <span class="font-sans text-2xl md:text-3xl font-bold text-text stat-number">2,000+</span>
          <span class="block font-mono text-[10px] text-muted mt-0.5 tracking-wide uppercase">Developers Educated</span>
        </div>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animate-fade-in-d5">
      <a
        href="#projects"
        class="group inline-flex items-center justify-center gap-2 font-sans text-sm font-medium bg-accent text-white px-8 py-3.5 rounded-lg hover:bg-[#D4652E] transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-accent/10"
      >
        View My Work
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center font-sans text-sm font-medium border border-border text-muted px-8 py-3.5 rounded-lg hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .hero-float {
    animation: heroFloat 6s ease-in-out infinite;
  }
</style>

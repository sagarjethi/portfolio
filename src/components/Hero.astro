---

---

<section id="hero" class="py-20 md:py-28 px-6 relative overflow-hidden min-h-[85vh] flex items-center">
  <!-- Subtle geometric background — pure CSS, no AI -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Warm gradient wash -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary to-accent/[0.03]"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.025]" style="background-image: linear-gradient(#E8763A 1px, transparent 1px), linear-gradient(90deg, #E8763A 1px, transparent 1px); background-size: 60px 60px;"></div>
    <!-- Large accent circle — top right -->
    <div class="absolute -top-32 -right-32 w-[500px] h-[500px] rounded-full border border-accent/[0.06]"></div>
    <div class="absolute -top-20 -right-20 w-[400px] h-[400px] rounded-full border border-accent/[0.04]"></div>
    <!-- Small accent circle — bottom left -->
    <div class="absolute -bottom-16 -left-16 w-[250px] h-[250px] rounded-full border border-accent/[0.05]"></div>
  </div>

  <!-- Floating 3D shapes — right side -->
  <div class="hidden md:block absolute right-0 top-0 bottom-0 w-[40%] pointer-events-none" aria-hidden="true">
    <img
      src="/images/hero-3d-1.jpg"
      alt=""
      class="hero-float absolute top-[10%] right-[10%] w-32 lg:w-40 rounded-2xl opacity-70 mix-blend-multiply drop-shadow-lg"
      style="animation-delay: 0s;"
      loading="eager"
    />
    <img
      src="/images/hero-3d-2.jpg"
      alt=""
      class="hero-float absolute top-[45%] right-[25%] w-28 lg:w-36 rounded-2xl opacity-60 mix-blend-multiply drop-shadow-lg"
      style="animation-delay: 2s;"
      loading="eager"
    />
    <img
      src="/images/hero-3d-3.jpg"
      alt=""
      class="hero-float absolute bottom-[12%] right-[8%] w-24 lg:w-32 rounded-2xl opacity-65 mix-blend-multiply drop-shadow-lg"
      style="animation-delay: 4s;"
      loading="eager"
    />
  </div>

  <div class="max-w-3xl mx-auto relative">
    <!-- Main headline -->
    <h1 class="font-sans text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-[1.15] mb-6 animate-fade-in animate-fade-in-d2">
      I build production blockchain<br class="hidden md:block" />
      systems that handle<br class="hidden md:block" />
      <span class="text-accent">real money</span> and <span class="text-accent">real users</span>.
    </h1>

    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mb-12 animate-fade-in animate-fade-in-d3">
      Over 10 years of shipping smart contracts, DeFi protocols, and AI-powered platforms —
      from architecture to mainnet.
    </p>

    <!-- Stats — clean, no icons -->
    <div class="grid grid-cols-3 gap-6 md:gap-10 mb-12 animate-fade-in animate-fade-in-d4">
      <div class="border-l-2 border-accent/30 pl-4">
        <span class="font-sans text-2xl md:text-3xl font-bold text-text">30+</span>
        <span class="block font-mono text-[10px] text-muted mt-1 tracking-wide uppercase">Projects Delivered</span>
      </div>
      <div class="border-l-2 border-accent/30 pl-4">
        <span class="font-sans text-2xl md:text-3xl font-bold text-text">20+</span>
        <span class="block font-mono text-[10px] text-muted mt-1 tracking-wide uppercase">Hackathons Won</span>
      </div>
      <div class="border-l-2 border-accent/30 pl-4">
        <span class="font-sans text-2xl md:text-3xl font-bold text-text">2,000+</span>
        <span class="block font-mono text-[10px] text-muted mt-1 tracking-wide uppercase">Devs Educated</span>
      </div>
    </div>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 animate-fade-in animate-fade-in-d5">
      <a
        href="#projects"
        class="group inline-flex items-center justify-center gap-2 font-sans text-sm font-medium bg-accent text-white px-8 py-3.5 rounded-lg hover:bg-[#D4652E] transition-all duration-200 shadow-sm hover:shadow-md hover:shadow-accent/10"
      >
        View My Work
        <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center justify-center font-sans text-sm font-medium border border-border text-muted px-8 py-3.5 rounded-lg hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  .hero-float {
    animation: heroFloat 6s ease-in-out infinite;
  }
</style>

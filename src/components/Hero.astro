---

---

<section id="hero" class="relative pt-32 pb-20 px-6 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute inset-0 dot-pattern opacity-30"></div>
  <div class="absolute top-20 left-1/4 w-72 h-72 bg-accent/5 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 right-1/4 w-96 h-96 bg-accent/3 rounded-full blur-3xl"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <!-- Photo with glow ring -->
    <div class="mb-8 relative inline-block">
      <div class="absolute inset-0 w-36 h-36 mx-auto rounded-full bg-accent/20 blur-xl"></div>
      <img
        src="/photo.jpg"
        alt="Sagar Jethi"
        class="relative w-32 h-32 rounded-full mx-auto object-cover object-top border-3 border-accent/40 shadow-lg shadow-accent/10"
        loading="eager"
      />
    </div>

    <!-- Name with decorative treatment -->
    <div class="mb-2">
      <span class="font-fira text-xs text-muted tracking-widest uppercase">Hello, I'm</span>
    </div>
    <h1 class="font-sora text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-4">
      Sagar <span class="text-accent">Jethi</span>
    </h1>

    <div class="flex items-center justify-center gap-3 mb-8">
      <div class="h-px w-12 bg-accent/40"></div>
      <p class="font-fira text-accent text-sm md:text-base tracking-wide">
        AI Developer & Blockchain Architect | Founder of Code Minto | Chainlink Advocate, Ahmedabad
      </p>
      <div class="h-px w-12 bg-accent/40"></div>
    </div>

    <p class="text-muted text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-4">
      Full-stack engineer with <span class="text-text font-semibold">10+ years</span> shipping production software,
      including <span class="text-text font-semibold">8+ years</span> in blockchain and
      <span class="text-text font-semibold">2.5 years</span> building AI agents.
    </p>

    <p class="text-muted text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-10">
      From smart contracts that enabled <span class="text-accent font-semibold">$5M+ raised</span> by projects,
      to <span class="text-accent font-semibold">30+ AI agents</span> powering real-time automation across DeFi, privacy, and social platforms
      — with <span class="text-accent font-semibold">$200K+ TVL</span> and <span class="text-accent font-semibold">$3.4M+ funding</span> at Velvet Capital,
      and <span class="text-accent font-semibold">$10K+ hackathon wins</span> building Web3Agent and other products.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#projects"
        class="inline-block font-fira text-sm bg-accent text-primary px-8 py-3.5 font-medium hover:bg-accent/90 transition-all duration-200 shadow-lg shadow-accent/20"
      >
        View My Work
      </a>
      <a
        href="#contact"
        class="inline-block font-fira text-sm border border-border text-muted px-8 py-3.5 hover:border-accent hover:text-accent transition-all duration-200"
      >
        Get In Touch
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-16 animate-bounce">
      <svg class="w-5 h-5 mx-auto text-muted/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

---
const education = [
  {
    degree: 'Masters of Computer Application',
    institution: 'B H Gardi College of Engineering and Technology',
    period: '2012 - 2015',
  },
  {
    degree: 'Bachelor of Computer Application',
    institution: 'Sanskar Institute of Management & Information Technology',
    period: '2010 - 2012',
  },
];
---

<section id="education" class="py-24 px-6 section-alt">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <span class="font-fira text-xs text-accent tracking-widest uppercase block mb-3">Background</span>
      <h2 class="font-sora text-3xl md:text-4xl font-bold inline-block section-title">Education</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {education.map(edu => (
        <div class="glow-card rounded-lg p-6 text-center">
          <span class="font-fira text-xs text-muted block mb-3">{edu.period}</span>
          <p class="font-sora font-semibold text-text text-lg mb-2">{edu.degree}</p>
          <p class="text-muted text-sm">{edu.institution}</p>
        </div>
      ))}
    </div>
  </div>
</section>

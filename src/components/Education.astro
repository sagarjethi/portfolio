---
const education = [
  {
    degree: 'Masters of Computer Application',
    short: 'MCA',
    institution: 'B H Gardi College of Engineering and Technology',
    period: '2012 - 2015',
  },
  {
    degree: 'Bachelor of Computer Application',
    short: 'BCA',
    institution: 'Sanskar Institute of Management & Information Technology',
    period: '2010 - 2012',
  },
];
---

<section id="education" class="py-20 px-6">
  <div class="max-w-4xl mx-auto">
    <!-- Visual -->
    <div class="mb-10 rounded-xl overflow-hidden border border-border/40">
      <img src="/images/education-visual.jpg" alt="Academic and computer science education" class="w-full h-40 md:h-48 object-cover opacity-85" loading="lazy" />
    </div>

    <div class="mb-14">
      <h2 class="font-sans text-2xl md:text-3xl font-bold text-text">
        Education
      </h2>
      <div class="mt-2 w-10 h-1 rounded-full bg-accent"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-5 max-w-2xl">
      {education.map(edu => (
        <div class="bg-card border border-border rounded-xl p-6 hover:shadow-sm transition-shadow duration-200">
          <div class="flex items-center justify-between mb-3">
            <span class="font-mono text-xs text-muted">{edu.period}</span>
            <span class="font-sans text-xs font-semibold text-accent bg-accent/10 px-2 py-0.5 rounded">{edu.short}</span>
          </div>
          <p class="font-sans font-semibold text-text mb-1.5">{edu.degree}</p>
          <p class="text-sm text-muted leading-relaxed">{edu.institution}</p>
        </div>
      ))}
    </div>
  </div>
</section>

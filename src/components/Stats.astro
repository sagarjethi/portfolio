---
const stats = [
  { number: '10+', label: 'Years Shipping Code', icon: '⟐' },
  { number: '30+', label: 'Projects & Clients Delivered', icon: '◈' },
  { number: '20+', label: 'Hackathons Won & Mentored', icon: '△' },
  { number: '2,000+', label: 'Students & Developers Educated', icon: '◉' },
];
---

<section class="section-accent-bg py-20 px-6">
  <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
    {stats.map((stat, i) => (
      <div class="text-center p-6 rounded-lg bg-primary/50 border border-border/50 backdrop-blur-sm hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5">
        <div class="font-fira text-accent/40 text-2xl mb-3">{stat.icon}</div>
        <div class="font-sora text-3xl md:text-4xl font-bold text-accent mb-2">
          {stat.number}
        </div>
        <div class="font-fira text-xs text-muted tracking-wide uppercase">
          {stat.label}
        </div>
      </div>
    ))}
  </div>
</section>

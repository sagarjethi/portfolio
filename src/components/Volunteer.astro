---

---

<section id="volunteer" class="py-24 px-6 section-accent-bg">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <span class="font-fira text-xs text-accent tracking-widest uppercase block mb-3">Giving Back</span>
      <h2 class="font-sora text-3xl md:text-4xl font-bold inline-block section-title">Volunteer & Community</h2>
    </div>

    <div class="glow-card rounded-xl p-8 md:p-10">
      <div class="grid md:grid-cols-[1fr_auto] gap-8 items-start">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="font-fira text-[10px] bg-accent/10 text-accent px-2.5 py-1 rounded-full border border-accent/20">Active</span>
            <span class="font-fira text-xs text-muted">Mar 2022 - Present</span>
          </div>

          <h3 class="font-sora text-2xl font-bold text-text mb-1">Chainlink Labs</h3>
          <p class="font-fira text-sm text-accent mb-6">Chainlink Advocate, Ahmedabad</p>

          <ul class="space-y-3 mb-8">
            <li class="text-muted leading-relaxed pl-5 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-2 before:h-2 before:rounded-full before:bg-accent/40">
              Hosted <span class="text-text font-medium">15+ events</span> and workshops reaching <span class="text-text font-medium">2,000+ students</span> to kickstart their blockchain learning journey across Ahmedabad.
            </li>
            <li class="text-muted leading-relaxed pl-5 relative before:content-[''] before:absolute before:left-0 before:top-[9px] before:w-2 before:h-2 before:rounded-full before:bg-accent/40">
              Educated developers and communities on <span class="text-text font-medium">decentralized oracle networks</span> and smart contract integrations.
            </li>
          </ul>

          <!-- Impact metrics -->
          <div class="flex flex-wrap gap-6">
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
                <span class="font-sora text-lg font-bold text-accent">15+</span>
              </div>
              <div>
                <div class="font-sora text-sm font-semibold text-text">Events</div>
                <div class="font-fira text-xs text-muted">Workshops hosted</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
                <span class="font-sora text-base font-bold text-accent">2K+</span>
              </div>
              <div>
                <div class="font-sora text-sm font-semibold text-text">Students</div>
                <div class="font-fira text-xs text-muted">Blockchain learners</div>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center">
                <span class="font-sora text-lg font-bold text-accent">4+</span>
              </div>
              <div>
                <div class="font-sora text-sm font-semibold text-text">Years</div>
                <div class="font-fira text-xs text-muted">Active advocacy</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative side element -->
        <div class="hidden md:flex flex-col items-center gap-4">
          <div class="w-20 h-20 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center">
            <svg class="w-10 h-10 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="font-fira text-[10px] text-muted tracking-wider uppercase">Chainlink</span>
        </div>
      </div>
    </div>
  </div>
</section>

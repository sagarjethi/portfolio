---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section id="blog" class="py-24 px-6 bg-primary">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-baseline justify-between mb-2">
      <h2 class="font-sans text-2xl font-bold text-text">Blog</h2>
      <a href="/blog" class="font-mono text-sm text-accent hover:underline">View all &rarr;</a>
    </div>
    <div class="w-12 h-0.5 bg-accent mb-10"></div>

    <div class="space-y-5">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="group block">
          <article class="bg-card border border-border/60 rounded-xl p-5 hover:border-accent/30 hover:shadow-sm transition-all duration-200">
            <time class="font-mono text-xs text-muted mb-2 block">{formatDate(post.data.date)}</time>
            <h3 class="font-sans font-semibold text-text group-hover:text-accent transition-colors mb-2">
              {post.data.title}
            </h3>
            <p class="text-muted text-sm leading-relaxed">
              {post.data.description.slice(0, 120)}{post.data.description.length > 120 ? '...' : ''}
            </p>
            <div class="flex gap-2 mt-3">
              {post.data.tags.slice(0, 2).map(tag => (
                <span class="font-mono text-xs text-accent/70">{tag}</span>
              ))}
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>
